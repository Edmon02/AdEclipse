    "xpaths": [
      "//div[contains(@class, 'ytp-ad')]",
      "//ytd-ad-slot-renderer",
      "//div[@id='player-ads']",
      "//span[contains(text(), 'Ad')]//ancestor::ytd-compact-promoted-video-renderer"
    ]
